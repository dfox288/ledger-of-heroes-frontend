# Nuxt Frontend Environment Variables
# Copy this file to .env and adjust values for your setup.

# ---------------------------------------------------------------------------
# Backend environment selector (server-side only)
# ---------------------------------------------------------------------------
# Selects which backend URL the Nitro proxy talks to. The actual URL is
# resolved in nuxt.config.ts — do NOT set NUXT_API_BASE_SERVER directly.
#
#   dev     -> http://host.docker.internal:8080/api/v1 (active backend dev)
#   stable  -> http://host.docker.internal:8081/api/v1 (stable, known-good API)
#
# After changing this, restart the dev server: `just restart`
NUXT_BACKEND_ENV=dev

# ---------------------------------------------------------------------------
# Public runtime config (exposed to the browser)
# ---------------------------------------------------------------------------

# Link to API documentation (rendered in the UI where applicable).
NUXT_PUBLIC_API_DOCS_URL=http://localhost:8080/docs/api

# AI image provider for generated hero/card art.
NUXT_PUBLIC_IMAGE_PROVIDER=stability-ai
